apiVersion: external-secrets.io/v1
kind: SecretStore
metadata:
  name: "{{ external_secrets_secret_store.name }}"
  namespace: "{{ external_secrets_secret_store.namespace | default(external_secrets_namespace) }}"
{% if external_secrets_secret_store.labels is defined %}
  labels: {{ external_secrets_secret_store.labels }}
{% endif %}
{% if external_secrets_secret_store.annotations is defined %}
  annotations: {{ external_secrets_secret_store.annotations }}
{% endif %}
spec:
{{ external_secrets_secret_store.spec | ansible.builtin.to_nice_yaml | indent(width=2, first=true) }}
