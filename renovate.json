{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>plopoyop/renovate-config",
    "github>plopoyop/renovate-config:kubernetes-ansible-collection",
    "github>plopoyop/renovate-config:automerge-devbox"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "zammad"
      ],
      "registryUrls": [
        "https://zammad.github.io/zammad-helm"
      ]
    },
    {
      "matchDatasources": [
        "github-releases"
      ],
      "matchPackageNames": [
        "tweedegolf/mailcrab"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "gatus"
      ],
      "registryUrls": [
        "https://twin.github.io/helm-charts"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "atlantis"
      ],
      "registryUrls": [
        "https://runatlantis.github.io/helm-charts"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "argo-cd"
      ],
      "registryUrls": [
        "https://argoproj.github.io/argo-helm"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "clamav"
      ],
      "registryUrls": [
        "https://wiremind.github.io/wiremind-helm-charts"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "headlamp"
      ],
      "registryUrls": [
        "https://kubernetes-sigs.github.io/headlamp/"
      ]
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/warp-tech/helm-charts/warpgate",
        "ghcr.io/warp-tech/warpgate"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "gitlab-runner"
      ],
      "registryUrls": [
        "https://charts.gitlab.io"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "oauth2-proxy"
      ],
      "registryUrls": [
        "https://oauth2-proxy.github.io/manifests"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "Zammad\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "zammad",
      "autoReplaceStringTemplate": "Zammad         | v{{newValue}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/zammad/defaults/main.yml$/",
        "/roles/zammad/README.md$/"
      ],
      "matchStrings": [
        "zammad_helm_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "zammad",
      "autoReplaceStringTemplate": "zammad_helm_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/mailcrab/defaults/main.yml$/",
        "/roles/mailcrab/README.md$/"
      ],
      "matchStrings": [
        "mailcrab_github_version:\\s*(?<quote>\")?v?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "tweedegolf/mailcrab",
      "autoReplaceStringTemplate": "mailcrab_github_version: {{#if quote}}\"v{{newValue}}\"{{else}}v{{newValue}}{{/if}}",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "Mailcrab\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "tweedegolf/mailcrab",
      "autoReplaceStringTemplate": "Mailcrab         | v{{newValue}}",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/gatus/defaults/main.yml$/",
        "/roles/gatus/README.md$/"
      ],
      "matchStrings": [
        "gatus_helm_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "gatus",
      "autoReplaceStringTemplate": "gatus_helm_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
