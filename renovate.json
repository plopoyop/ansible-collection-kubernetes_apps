{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>plopoyop/renovate-config",
    "github>plopoyop/renovate-config:kubernetes-ansible-collection",
    "github>plopoyop/renovate-config:automerge-devbox"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "zammad"
      ],
      "registryUrls": [
        "https://zammad.github.io/zammad-helm"
      ]
    },
    {
      "matchDatasources": [
        "github-releases"
      ],
      "matchPackageNames": [
        "tweedegolf/mailcrab"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "gatus"
      ],
      "registryUrls": [
        "https://twin.github.io/helm-charts"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "atlantis"
      ],
      "registryUrls": [
        "https://runatlantis.github.io/helm-charts"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "argo-cd"
      ],
      "registryUrls": [
        "https://argoproj.github.io/argo-helm"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "clamav"
      ],
      "registryUrls": [
        "https://wiremind.github.io/wiremind-helm-charts"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "Zammad\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "zammad",
      "autoReplaceStringTemplate": "Zammad         | v{{newValue}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/zammad/defaults/main.yml$/",
        "/roles/zammad/README.md$/"
      ],
      "matchStrings": [
        "zammad_helm_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "zammad",
      "autoReplaceStringTemplate": "zammad_helm_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/mailcrab/defaults/main.yml$/",
        "/roles/mailcrab/README.md$/"
      ],
      "matchStrings": [
        "mailcrab_github_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "tweedegolf/mailcrab",
      "autoReplaceStringTemplate": "mailcrab_github_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "Mailcrab\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "tweedegolf/mailcrab",
      "autoReplaceStringTemplate": "Mailcrab         | v{{newValue}}",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/gatus/defaults/main.yml$/",
        "/roles/gatus/README.md$/"
      ],
      "matchStrings": [
        "gatus_helm_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "gatus",
      "autoReplaceStringTemplate": "gatus_helm_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "Gatus\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "gatus",
      "autoReplaceStringTemplate": "Gatus         | v{{newValue}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/atlantis/defaults/main.yml$/",
        "/roles/atlantis/README.md$/"
      ],
      "matchStrings": [
        "atlantis_helm_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "atlantis",
      "autoReplaceStringTemplate": "atlantis_helm_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "Atlantis\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "atlantis",
      "autoReplaceStringTemplate": "Atlantis | v{{newValue}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/argocd/defaults/main.yml$/",
        "/roles/argocd/README.md$/"
      ],
      "matchStrings": [
        "argocd_helm_chart_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "argo-cd",
      "autoReplaceStringTemplate": "argocd_helm_chart_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "Argo CD\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "argo-cd",
      "autoReplaceStringTemplate": "Argo CD | v{{newValue}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/roles/clamav/defaults/main.yml$/",
        "/roles/clamav/README.md$/"
      ],
      "matchStrings": [
        "clamav_helm_version:\\s*(?<quote>\")?(?<currentValue>[0-9\\.]+)\"?"
      ],
      "depNameTemplate": "clamav",
      "autoReplaceStringTemplate": "clamav_helm_version: {{#if quote}}\"{{newValue}}\"{{else}}{{newValue}}{{/if}}",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README.md$/"
      ],
      "matchStrings": [
        "ClamAV\\s*\\|\\s*v?(?<currentValue>[0-9\\.]+)"
      ],
      "depNameTemplate": "clamav",
      "autoReplaceStringTemplate": "ClamAV         | v{{newValue}}",
      "datasourceTemplate": "helm"
    }
  ]
}
